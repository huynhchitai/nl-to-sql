# ─── Google Cloud / Vertex AI ────────────────────────────────────────────────
# Your GCP project ID (required)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region where Vertex AI is enabled (defaults to us-central1)
GOOGLE_CLOUD_REGION=us-central1

# Option A: path to a GCP service-account JSON key file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa.json

# Option B: single-line JSON of the service-account key (Vercel / CI)
# Mutually exclusive with GOOGLE_APPLICATION_CREDENTIALS — if both are set,
# GOOGLE_APPLICATION_CREDENTIALS takes precedence.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Both values are required for rate limiting to be active.
# If either is missing the app degrades gracefully — rate limiting becomes a no-op.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
